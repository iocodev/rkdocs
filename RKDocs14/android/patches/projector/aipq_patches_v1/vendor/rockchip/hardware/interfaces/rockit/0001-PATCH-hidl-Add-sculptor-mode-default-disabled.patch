+void setValue(RockitHWParamPairs& param, uint32_t key, uint64_t value) {
+    int size = param.counter;
+    param.counter ++;
+    param.pairs[size].key = key;
+    param.pairs[size].value = value;
+}
+
+int SculptorCtrl::getSculptorOutFrame(RockitHWBuffer& hwBuffer, void* mCtx, bool mDebug) {
+    //ATRACE_CALL();
+    int  ret = 0;
+    int  err = MPP_OK;
+    uint64_t pts = 0;
+    MppBufferCtx* bufferCtx = nullptr;
+    sculptor_buffer sculptorBuffer = nullptr;
+    RockitHWParamPairs &param = hwBuffer.pair;
+    sculptor_dci_info dci_info;
+
+    sculptorBuffer = sculptor_get_out_buffer(mSculptorCtx);
+    if (sculptorBuffer == nullptr) {//err != MPP_OK ||
+        if(mDebug)
+            ALOGE(" sculptor_get_out_buffer -1 =====================");
+        return -1;
+    }
+
+    bufferCtx = (MppBufferCtx*)findMppBufferBySculptorBuffer(sculptorBuffer, mCtx);
+    if (!bufferCtx) {
+        ret = -1;
+        ALOGE("get outdated mppBuffer %p", sculptorBuffer);
+        goto cleanUp;
+    }
+
+    if (bufferCtx) {
+        sculptor_frame_t sculptorFrameInfos;
+        sculptor_buffer_get_frame_infos(mSculptorCtx, sculptorBuffer, &sculptorFrameInfos);
+        bufferCtx->mSite = 1;
+        hwBuffer.bufferId = bufferCtx->mUniqueID;
+
+        if (mDebug) {
+            ALOGD("%s get this buffer, fd %d sculptorBuffer %p",
+                   __FUNCTION__, hwBuffer.bufferId, sculptorBuffer);
+        }
+        //entry->flags = flags;
+
+        pts = sculptorFrameInfos.pts;
+        sculptor_buffer_ref_add(mSculptorCtx, sculptorBuffer);
+
+        ret = sculptor_buffer_get_dci_info(mSculptorCtx,sculptorBuffer,&dci_info);
+
+        if (mDebug)
+            ALOGD("get outdated meta offset =%d,size = %d",(int)dci_info.offset,(int)dci_info.size);
+        if (ret == MPP_OK) {
+            setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_HDR_META_OFFSET,
+                    (uint64_t)dci_info.offset);
+            setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_HDR_META_SIZE,
+                    (uint64_t)dci_info.size);
+	    }
+
+        setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_WIDTH_STRIDE,
+            (uint64_t)sculptorFrameInfos.vir_width);
+        setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_HEIGHT_STRIDE,
+            (uint64_t)sculptorFrameInfos.vir_height);
+        setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_WIDTH,
+            (uint64_t)sculptorFrameInfos.width);
+        setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_HEIGHT,
+            (uint64_t)sculptorFrameInfos.height);
+
+        setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_FORMAT, mFormat);
+        setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_PTS,
+            (uint64_t)pts);
+        setValue(param, (uint32_t)RockitHWParamKey::HW_KEY_DTS,
+            (uint64_t)pts);
+        if(mDebug)
+            ALOGD("get one sculptor frame [%d:%d] stride [%d:%d]  err %d index %d ",
+            sculptorFrameInfos.width, sculptorFrameInfos.height, sculptorFrameInfos.vir_width, sculptorFrameInfos.vir_height, err, bufferCtx->mFd);
+    } else {
+        ALOGE("getSculptorOutFrame failed -------------------------");
+    }
+
+cleanUp:
+    //entry->flags = flags;
+
+    return ret;
+}
+
+int SculptorCtrl::checkMppFrameStatus(MppFrame mpp_frame, bool mDebug) {
+        int  ret = 1;
+        int  eos = 0;
+        int  infochange = 0;
+        // get media buffer from mpp buffer
+        infochange = mpp_frame_get_info_change(mpp_frame);
+        eos = mpp_frame_get_eos(mpp_frame);
+        if ((mpp_frame_get_errinfo(mpp_frame) || mpp_frame_get_discard(mpp_frame))
+           && mSculptorCtx) {
+            if(mDebug)
+              ALOGD("%s ====  err info   sculptor need skip this frame to rockit ++++++x",__FUNCTION__);
+            ret = -2;
+            //goto __FAILED;
+        }
+
+        if(infochange && mSculptorCtx){
+            if(mDebug)
+              ALOGD("%s ====  infochange   sculptor need skip frame to rockit ++++++x",__FUNCTION__);
+            //bufferReady();
+            ret = -1;
+            //goto __FAILED;
+        }
+
+        if(eos && mSculptorCtx){
+            if(mDebug)
+              ALOGD("%s ====  eos  sculptor_reset=== start++++++x",__FUNCTION__);
+            ret = 0;
+            resetSculptor();
+            if(mDebug)
+                ALOGD("%s ====  eos sculptor_reset===",__FUNCTION__);
+        }
+        return ret;
+}
+
+
+static bool Rockchip_VF_GetEnvU32(const char *name, uint32_t *value, uint32_t default_value)
+{
+    bool ret = true;
+    char prop[PROP_VALUE_MAX + 1];
+    int len = __system_property_get(name, prop);
+    if (len > 0) {
+        char *endptr;
+        int base = (prop[0] == '0' && prop[1] == 'x') ? (16) : (10);
+        errno = 0;
+        *value = strtoul(prop, &endptr, base);
+        if (errno || (prop == endptr)) {
+            errno = 0;
+            *value = default_value;
+        }
+    } else {
+        *value = default_value;
+    }
+
+    return ret;
+}
+
+static void sculptorMppFrameRdyCb(void* data) {
+    MppBuffer mpp_buffer = (MppBuffer)data;
+    if (mpp_buffer) {
+        mpp_buffer_put(mpp_buffer);
+    }
+}
+
+bool SculptorCtrl::getSculptorMode(int width, int height) {
+    uint32_t value = 0;
+    float verticalAspectRatio1_1 = 1.0f;
+    float aspectRatio = static_cast<float>(width) / height;
+    if ((height > width) ||abs(aspectRatio - verticalAspectRatio1_1) < 0.02f) {
+        mSculptorMode = 0;
+    } else {
+        if ((width <= 1920||mSrOnly)
+            && mRotation == 0 && !MPP_FRAME_FMT_IS_YUV_10BIT(mFormat)) {
+            Rockchip_VF_GetEnvU32("persist.vendor.sculptor.mode", &value, 1);
+	}
+
+        mSculptorMode = value;
+    }
+    return mSculptorMode;
+}
+
+bool SculptorCtrl::getSculptorDebug() {
+    uint32_t value = 0;
+    Rockchip_VF_GetEnvU32("rockit.hw.hidl.debug", &value, 0);
+    if(value)
+       return true;
+    return false;
+}
+
+MppBufferGroup SculptorCtrl::initSculptorGrp() {
+    MppBufferGroup      frm_grp = NULL;
+    if(mSculptorMode){
+        MPP_RET             err     = MPP_OK;
+        ALOGE("%s init internal frame grp++++", __FUNCTION__);
+        // init internal frame grp
+        err = mpp_buffer_group_get_internal(&frm_grp, MPP_BUFFER_TYPE_ION);
+        if (err != MPP_OK) {
+            ALOGE("%s unsupport rockit codec id", __FUNCTION__);
+            //goto FAIL;
+        }
+
+        err = mpp_buffer_group_limit_config(&frm_grp, 0, 30);
+        if (err != MPP_OK) {
+            ALOGE("%s config mpp buffer group limit fail !", __FUNCTION__);
+            //goto FAIL;
+        }
+    }
+    return frm_grp;
+}
+
+bool SculptorCtrl::checkSculptorCache(int mWidth, bool mDebug) {
+    int number = sculptor_buffer_get_unused_counts(mSculptorCtx);
+    int cacheFull = scluptor_check_input_cache_full(mSculptorCtx);
+    int minCacheBuffers = 8;
+    if (mWidth == 3840)
+        minCacheBuffers = 2;
+    if(number < minCacheBuffers || cacheFull != SCULPTOR_ERROR_OKAY){
+        if(mDebug)
+            ALOGD("sculptor get cache is full or get unused number %d less than limit,skip decode_get_frame", number);
+        //ret = -1;
+        return false;
+    }
+    return true;
+}
+
+sclptor_init_sizes_t SculptorCtrl::initSculptor(int mWidth, int mHeight, int rotation, int format) {
+    int mWStride=0;
+    int mHStride=0;
+    int ret = 0;
+    uint32_t value = 0;
+    uint32_t type = 0;
+    mRotation = rotation;
+    mFormat = format;
+    mSrOnly = false;
+    sclptor_init_sizes_t parms = {0,0,0,0};
+    __system_property_set("rt_vpp_act_res","");
+    __system_property_set("rt_vpp_vir_res","");
+    __system_property_set("rt_vpp_fps","0");
+
+    ALOGE("initSculptor: w %d h %d  mSculptorMode %d", mWidth, mHeight, getSculptorMode(mWidth,mHeight));
+    if (!getSculptorMode(mWidth,mHeight) || (mWidth > 1920))
+        return parms;
+
+    // 1.实宽实高1080P片源，虚宽虚高不需要改，按照rockit配置的
+    // 2.其他<1080P H265片源，需要修改虚宽虚高，实宽实高
+
+    Rockchip_VF_GetEnvU32("persist.vendor.sculptor.sronly", &value, 0);
+    if (value) {
+        __system_property_set("rt_vpp_act_res","3840x2160");
+        __system_property_set("rt_vpp_vir_res","3840x2160");
+        __system_property_set("rt_vpp_fps","0");
+        type = SCULPTOR_PROCESS_TYPE_SR;
+        mWidth = 3840;
+        mHeight = 2160;
+        mWStride = 3840;
+        mHStride = 2160;
+        mSrOnly = true;
+    } else {
+        __system_property_set("rt_vpp_act_res","1920x1080");
+        __system_property_set("rt_vpp_vir_res","1920x1088");
+        __system_property_set("rt_vpp_fps","60");
+        Rockchip_VF_GetEnvU32("persist.vendor.sculptor.enable.fe", &value, 0);
+        if (value && mWidth <=960 && mHeight <= 540)
+            __system_property_set("rt_vpp_fps","0");
+        else
+            __system_property_set("rt_vpp_fps","60");
+        type = SCULPTOR_PROCESS_TYPE_SR | SCULPTOR_PROCESS_TYPE_MEMC;
+        mWidth = 1920;
+        mHeight = 1080;
+        mWStride = 1920;
+        mHStride = 1088;
+    }
+    ALOGE("initSculptor sculptor_create ----------------------------------------s");
+
+    if (mSculptorCtx == NULL)
+        ret = sculptor_create(type, &mSculptorCtx);
+
+    if (mSculptorCtx == NULL)
+        return parms;
+    parms.width = mWidth;
+    parms.height = mHeight;
+    parms.wstride = mWStride;
+    parms.hstride = mHStride;
+    ALOGE("initSculptor sculptor_create ----------------------------------------e");
+
+    return parms;
+}
+
+/* copy output MppBuffer, if not output buffer specified, copy to mOutBlock default. */
+int SculptorCtrl::doSculptorProcess(MppFrame frame) {
+    //ATRACE_CALL();
+    MppBuffer mppBuffer = mpp_frame_get_buffer(frame);
+    sculptor_frame_t sculptorFrame;
+    uint32_t mppFormat;
+
+    memset(&sculptorFrame, 0, sizeof(sculptor_frame_t));
+    sculptorFrame.prime_fd = mpp_buffer_get_fd(mppBuffer);
+    sculptorFrame.size = mpp_buffer_get_size(mppBuffer);
+    sculptorFrame.width = mpp_frame_get_width(frame);
+    sculptorFrame.height = mpp_frame_get_height(frame);
+    sculptorFrame.vir_width = mpp_frame_get_hor_stride(frame);
+    sculptorFrame.vir_height = mpp_frame_get_ver_stride(frame);
+    sculptorFrame.stride = mpp_frame_get_hor_stride(frame);
+    mppFormat = mpp_frame_get_fmt(frame);
+    if (!MPP_FRAME_FMT_IS_YUV_10BIT(mppFormat))
+        sculptorFrame.drm_format = DRM_FORMAT_NV12;
+    else
+        sculptorFrame.drm_format = DRM_FORMAT_NV15;
+
+    sculptorFrame.drm_modifier = 0;
+    sculptorFrame.pts = mpp_frame_get_pts(frame);
+    sculptorFrame.callback = sculptorMppFrameRdyCb;
+    sculptorFrame.private_data = mppBuffer;
+
+    sculptor_sculpt(mSculptorCtx, &sculptorFrame);
+
+    return 0;
+}
+
+sculptor_buffer SculptorCtrl::commitSculptorBuffer(uint32_t fd, uint32_t size, uint32_t width, uint32_t height,
+                                uint32_t vir_width, uint32_t vir_height, uint32_t stride, sculptor_callback callback,
+                                void * private_data){
+    sculptor_frame_t sframe;
+
+    memset(&sframe, 0, sizeof(sframe));
+    sframe.prime_fd = fd;
+    sframe.addrs = nullptr;
+    sframe.size = size;
+    sframe.width = width;
+    sframe.height = height;
+    sframe.vir_width = vir_width;
+    sframe.vir_height = vir_height;
+    sframe.stride = stride;
+    sframe.drm_format = DRM_FORMAT_NV12;
+    sframe.drm_modifier = 0;
+    sframe.callback = callback;
+    sframe.private_data = private_data;
+    return sculptor_buffer_commit(mSculptorCtx, &sframe);
+}
+
+void SculptorCtrl::resetSculptor() {
+    ALOGE("%s: sculptor_reset-----------------------s", __FUNCTION__);
+    sculptor_reset(mSculptorCtx);
+    ALOGE("%s: sculptor_reset-----------------------e", __FUNCTION__);
+}
+
+void SculptorCtrl::deinitSculptor() {
+    ALOGE("%s: sculptor_deinit-----------------------s", __FUNCTION__);
+    __system_property_set("rt_vpp_act_res","");
+    __system_property_set("rt_vpp_vir_res","");
+    __system_property_set("rt_vpp_fps","0");
+    sculptor_reset(mSculptorCtx);
+    sculptor_destroy(mSculptorCtx);
+    mSculptorCtx = nullptr;
+    ALOGE("%s: sculptor_deinit-----------------------e", __FUNCTION__);
+}

+c2_status_t C2RKMpiDec::getSculptorOutFrame(OutWorkEntry* entry) {
+    c2_status_t  ret = C2_OK;
+    int          err = MPP_OK;
+    uint32_t     flags = 0;
+
+    uint64_t     pts = 0;
+    OutBuffer*   outBuffer = nullptr;
+    sculptor_buffer sculptorBuffer = nullptr;
+    sculptor_dci_info dci_info;
+
+    if(isPendingFlushing()){
+        c2_trace("skip buffer when Flushed---");
+        return C2_CANCELED;
+    }
+
+    sculptorBuffer = sculptor_get_out_buffer(mSculptorCtrl->getSculptorCtx());
+    if (sculptorBuffer == nullptr) {//err != MPP_OK ||
+        c2_err(" sculptor_get_out_buffer null ,skip =====================");
+        return C2_CANCELED;
+    }
+
+    outBuffer = findOutBufferBySculptorBuffer(sculptorBuffer);
+    if (!outBuffer) {
+        ret = C2_CANCELED;
+        c2_err("outBuffer maybe clearout,get outdated sculptorBuffer %p,skip", sculptorBuffer);
+        goto cleanUp;
+    }
+
+    if (outBuffer) {
+        sculptor_frame_t sculptorFrameInfos;
+        sculptor_buffer_get_frame_infos(mSculptorCtrl->getSculptorCtx(), sculptorBuffer, &sculptorFrameInfos);
+        outBuffer->mStatus = OutBuffer::OWNED_BY_US;
+        entry->outblock = outBuffer->mBlock;
+        entry->timestamp = sculptorFrameInfos.pts;
+
+        entry->flags = flags;
+
+        pts = sculptorFrameInfos.pts;
+        sculptor_buffer_ref_add(mSculptorCtrl->getSculptorCtx(), sculptorBuffer);
+
+        sculptor_buffer_get_dci_info(mSculptorCtrl->getSculptorCtx(),sculptorBuffer,&dci_info);
+	    configFramePqMeta(dci_info,outBuffer->mBlock);
+
+        //c2_trace("get one sculptor frame [%d:%d] stride [%d:%d] pts %lld err %d index %d ,dci offset %lld",
+        //        sculptorFrameInfos.width, sculptorFrameInfos.height, sculptorFrameInfos.vir_width, sculptorFrameInfos.vir_height, pts, err, outBuffer->index,dci_info.offset);
+    } else {
+        c2_trace("getSculptorOutFrame failed skip-------------------------");
+        ret = C2_CANCELED;
+    }
+
+cleanUp:
+    entry->flags = flags;
+
+    return ret;
+}

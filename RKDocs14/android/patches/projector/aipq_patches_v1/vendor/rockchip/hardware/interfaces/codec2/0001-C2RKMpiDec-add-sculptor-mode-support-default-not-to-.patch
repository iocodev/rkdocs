+c2_status_t C2RKMpiDec::onSculptorFrameReady() {
+    c2_status_t err = C2_OK;
+    c2_trace_func_enter();
+
+sculptoroutframe:
+    OutWorkEntry entry;
+    memset(&entry, 0, sizeof(entry));
+
+    err = getSculptorOutFrame(&entry);
+    if (err == C2_OK) {
+        c2_trace("onSculptorFrameReady: get out frame & before finishWork==");
+        finishWork(entry);
+        if(mDisableSync)
+           ensureDecoderStateCb(this);
+        else
+           ensureDecoderState();
+        c2_trace("onSculptorFrameReady: get out frame & after finishWork---");
+    } else if (err == C2_NOT_FOUND) {
+        goto sculptoroutframe;
+    } else if (err == C2_CORRUPTED) {
+        c2_err("signalling error");
+        mSignalledError = true;
+    }
+
+    return err;
+}

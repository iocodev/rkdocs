+#if SCULPTOR_ENABLE
+c2_status_t C2RKMpiDec::commitBufferToSculptor(std::shared_ptr<C2GraphicBlock> block) {
+    c2_status_t err = C2_OK;
+    auto c2Handle = block->handle();
+    uint32_t fd = c2Handle->data[0];
+    buffer_handle_t handle = nullptr;
+
+    err = importGraphicBuffer(c2Handle, &handle);
+    if (err != C2_OK) return err;
+
+    uint32_t bufferId = C2RKGrallocOps::get()->getBufferId(handle);
+
+    OutBuffer *buffer = findOutBuffer(bufferId);
+    c2_trace("commitBufferToSculptor: buffer %p bufferId %d ", buffer, bufferId);
+    if (buffer) {
+        /* commit this buffer back to sculptor */
+        sculptor_buffer sculptorBuffer = buffer->sculptorBuffer;
+        if (sculptorBuffer) {
+            sculptor_buffer_ref_dec(mSculptorCtrl->getSculptorCtx(), sculptorBuffer);
+        }
+        buffer->mBlock = block;
+        buffer->mStatus = OutBuffer::OWNED_BY_SCULPTOR;
+
+        c2_trace("put this buffer, slot %d fd %d sculptorBuffer %p",
+                 bufferId, fd, sculptorBuffer);
+    } else {
+        sculptor_buffer sculptorBuffer = mSculptorCtrl->commitSculptorBuffer(fd,
+                                C2RKGrallocOps::get()->getAllocationSize(handle),
+                                mWidth, mHeight,mHorStride, mVerStride,
+                                C2RKGrallocOps::get()->getPixelStride(handle), sculptorFrameReadyCb,
+                                this);
+
+        OutBuffer *buffer = new OutBuffer;
+        buffer->mBufferId  = bufferId;
+        buffer->mMppBuffer = NULL;
+        buffer->sculptorBuffer = sculptorBuffer;
+        buffer->mBlock = block;
+        buffer->mStatus = OutBuffer::OWNED_BY_SCULPTOR;
+        sculptor_buffer_ref_dec(mSculptorCtrl->getSculptorCtx(), sculptorBuffer);
+        mOutBuffers.push(buffer);
+
+        c2_trace("sculptor import this buffer, slot %d fd %d size %d buffer %p  listSize %d ",
+                 bufferId, fd, (int)C2RKGrallocOps::get()->getAllocationSize(handle), buffer, (int)mOutBuffers.size());
+    }
+
+    freeGraphicBuffer(handle);
+
+    return C2_OK;
+}
+#endif

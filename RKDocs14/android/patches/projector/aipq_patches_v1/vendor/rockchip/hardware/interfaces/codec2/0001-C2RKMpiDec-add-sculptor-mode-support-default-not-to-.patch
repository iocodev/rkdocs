+    int  doSculptorProcess(MppFrame frame);
+    bool getSculptorMode(int width, int height, MppFrameFormat mColorFormat);
+    sclptor_init_sizes_t  initSculptor(int mWidth, int mHeight);
+    void deinitSculptor();
+    void resetSculptor();
+    sculptor_buffer commitSculptorBuffer(uint32_t fd, uint32_t size, uint32_t width, uint32_t height,
+                                uint32_t vir_width, uint32_t vir_height, uint32_t stride, sculptor_callback callback,
+                                void * private_data);
+
+    sculptor_context getSculptorCtx() { return mSculptorCtx; }
+#endif
+private:
+    bool mSculptorMode;
+#if SCULPTOR_ENABLE
+    /* SCULPTOR interface parameters*/
+    MppFrameFormat mCFormat;
+    sculptor_context   mSculptorCtx;
+    uint32_t mSculptorWidth;
+    uint32_t mSculptorHeight;
+    uint32_t mSculptorHorStride;
+    uint32_t mSculptorVerStride;
+#endif
+};
+
+#endif // SCULPTOR_CTRL_H__
